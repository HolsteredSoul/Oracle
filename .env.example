# =============================================================================
# ORACLE — Environment Variables
# =============================================================================
#
# Setup:
#   cp .env.example .env
#   # Edit .env and fill in your actual keys
#   # NEVER commit .env to version control (it's already in .gitignore)
#
# Minimum to run:
#   Only OPENROUTER_API_KEY is required. The agent can scan markets without
#   it, but will not produce probability estimates or place bets.
#
# Getting keys:
#   OpenRouter  — https://openrouter.ai/keys               (pay-as-you-go)
#   Betfair     — https://developer.betfair.com/            (free with account)
#   FRED        — https://fred.stlouisfed.org/docs/api/api_key.html  (free)
#   NewsAPI     — https://newsapi.org/register              (free, 100 req/day)
#   Manifold    — https://manifold.markets/ → Settings → API key  (free)
#   API-Sports  — https://api-sports.io/                   (free, 100 req/day)
#
# =============================================================================


# =============================================================================
# LLM — REQUIRED
# =============================================================================
# OpenRouter routes all LLM calls through a single key, providing access to
# Claude, Grok, GPT-4o, and others with automatic failover.
#
# Default model:   anthropic/claude-sonnet-4  (configured in config.toml)
# Fallback model:  x-ai/grok-4.1-fast         (configured in config.toml)
#
# [REQUIRED]
OPENROUTER_API_KEY=sk-or-...

# Alternative direct-provider keys — only needed if you change config.toml
# to set provider = "anthropic" or provider = "openai" instead of "openrouter".
# Leave commented out if you are using OpenRouter (the default).
#
# [OPTIONAL — only if changing provider in config.toml]
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...


# =============================================================================
# TRADING PLATFORMS
# =============================================================================

# --- Betfair Exchange (live / real-money execution) ---
# Required to enable live trading on the Betfair exchange.
# Set enabled = true under [platforms.betfair] in config.toml after filling
# these in. Get your app key at: https://developer.betfair.com/
#
# [REQUIRED for live trading]
BETFAIR_APP_KEY=...
BETFAIR_USERNAME=...
BETFAIR_PASSWORD=...

# --- Manifold Markets (paper trading / play-money validation) ---
# Market scanning on Manifold is public and requires no key.
# This key is only needed to place play-money bets for paper-trading
# validation. Get it at: https://manifold.markets/ → Settings → API key
#
# [OPTIONAL — enables paper-trading writes on Manifold]
MANIFOLD_API_KEY=...

# --- Interactive Brokers / ForecastEx (event contracts) ---
# Account ID for IBKR event contracts via TWS / IB Gateway.
# IB Gateway must be running locally or on a VPS.
#   Paper trading port: 4002 (default in config.toml)
#   Live trading port:  4001
#
# [OPTIONAL — only needed if using the IBKR ForecastEx platform]
IB_ACCOUNT_ID=U1234567


# =============================================================================
# DATA SOURCES
# =============================================================================

# --- FRED — Federal Reserve Economic Data ---
# Powers economics market enrichment (CPI, GDP, unemployment, fed funds rate).
# Free registration at: https://fred.stlouisfed.org/docs/api/api_key.html
#
# [RECOMMENDED — improves economics market accuracy]
FRED_API_KEY=...

# --- NewsAPI ---
# Provides news headlines for politics, culture, and current-events markets.
# Free tier: 100 requests/day. Register at: https://newsapi.org/register
#
# [RECOMMENDED — improves politics/culture market accuracy]
NEWS_API_KEY=...

# --- API-Sports ---
# Live sports scores and fixtures for sports market enrichment.
# Free tier: 100 requests/day. Register at: https://api-sports.io/
#
# [OPTIONAL — improves sports market accuracy]
API_SPORTS_KEY=...

# --- OpenWeatherMap ---
# ORACLE uses Open-Meteo by default for weather data (free, no key needed).
# This key is only relevant if you switch the weather provider to
# OpenWeatherMap in config.toml. Leave commented out unless you have done so.
#
# [OPTIONAL — only if switching weather provider in config.toml]
# OWM_API_KEY=...


# =============================================================================
# ALERTING
# =============================================================================

# --- Telegram ---
# Sends trade alerts and cycle summaries to a Telegram chat.
# Create a bot via @BotFather, then get your chat ID via @userinfobot.
#
# [OPTIONAL]
TG_BOT_TOKEN=...
TG_CHAT_ID=...


# =============================================================================
# RUNTIME / LOGGING
# =============================================================================

# --- Log verbosity ---
# Controls which log messages are shown (tracing-subscriber EnvFilter syntax).
# Examples:
#   oracle=debug          — verbose output for all ORACLE modules
#   oracle=trace          — maximum detail (very noisy)
#   oracle=info,reqwest=warn — quiet HTTP library, normal ORACLE output
#
# [OPTIONAL — default: oracle=info]
# RUST_LOG=oracle=info

# --- Structured JSON logging ---
# Set to 1 to emit logs as newline-delimited JSON instead of human-readable
# text. Useful for log aggregators (Datadog, Loki, etc.).
#
# [OPTIONAL — default: human-readable text]
# ORACLE_LOG_JSON=1
